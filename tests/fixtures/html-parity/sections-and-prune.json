{
  "id": "sections-and-prune",
  "url": "https://example.test/sections",
  "rules": {
    "rootSelector": "main, body",
    "sectionSelector": "section",
    "pruneSelectors": [
      "nav",
      ".remove-me"
    ]
  },
  "html": "<!doctype html><html><head><title>Sections</title></head><body><nav><a href=\"#gone\">Gone</a></nav><main><section id=\"s1\"><h2>One</h2><p>One body.</p><div class=\"remove-me\"><p>Removed content.</p></div></section><section id=\"s2\"><h2>Two</h2><p>Two body with <a href=\"#ref\">reference</a>.</p></section></main></body></html>"
}

